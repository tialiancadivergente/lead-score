PORT=3000
API_KEY_ENABLED=true
INTERNAL_API_KEY=change-me

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lead_score
DB_SSL=false
TYPEORM_SYNC=false
TYPEORM_LOGGING=false

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://example.servicebus.windows.net/;SharedAccessKeyName=app;SharedAccessKey=change-me
SERVICE_BUS_ENABLED=false
SERVICE_BUS_LEAD_SCORE_QUEUE=lead-score
SERVICE_BUS_CONSUMER_ENABLED=false
SERVICE_BUS_MAX_RETRIES=5
SERVICE_BUS_RETRY_DELAY_MS=200
SERVICE_BUS_MAX_RETRY_DELAY_MS=5000

# Fila: cadastro de leads
SERVICE_BUS_LEAD_REGISTRATION_QUEUE=lead-registration
SERVICE_BUS_LEAD_REGISTRATION_CONSUMER_ENABLED=false
SERVICE_BUS_LEAD_REGISTRATION_MAX_CONCURRENCY=5

# ActiveCampaign
ACTIVECAMPAIGN_BASE_URL=https://example.api-us1.com/api/3
ACTIVECAMPAIGN_API_TOKEN=change-me
ACTIVECAMPAIGN_CREATE_CONTACT_PATH=/api/3/contacts

# Google Ads OAuth
GOOGLE_ADS_CLIENT_ID=change-me.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=change-me
GOOGLE_ADS_DEVELOPER_TOKEN=change-me
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/google-ads/callback
GOOGLE_ADS_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords,openid,email,profile

# Meta OAuth
META_APP_ID=change-me
META_APP_SECRET=change-me
META_CONFIG_ID=change-me
META_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/meta/callback
META_OAUTH_SCOPES=ads_read,ads_management,business_management,email
META_API_VERSION=v22.0

# Marketing extraction
SERVICE_BUS_MARKETING_EXTRACT_QUEUE=marketing-extract
SERVICE_BUS_MARKETING_EXTRACT_CONSUMER_ENABLED=false
SERVICE_BUS_MARKETING_EXTRACT_MAX_CONCURRENCY=3
MARKETING_DASHBOARD_SCHEDULER_ENABLED=false
MARKETING_DASHBOARD_SCHEDULER_INTERVAL_MINUTES=60
